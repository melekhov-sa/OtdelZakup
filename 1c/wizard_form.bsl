// ============================================================================
// Модуль формы: Мастер обработки заявки
// Пошаговый визард: Этап 1 → Этап 2
// Вся HTTP-логика — в общем модуле РазборЗаявокAPI
// ============================================================================
//
// Реквизиты формы:
//   ТекущийЭтап     - Число(1)    - 0 = выбор источника, 1 = результат
//   ИсточникДанных  - Число(1)    - 0 = текст от МП, 1 = файл
//   ТекстОтМП       - Строка(0)   - многострочный текст сообщения
//   ПутьКФайлу      - Строка(500)
//   ТекстСтатистики - Строка(200)
//   ТекстПредупреждений - Строка(0) - сводка по пропущенным полям
//
// Табличная часть «Позиции»:
//   НомерСтроки, Наименование, Количество, ЕдИзмерения,
//   ТипИзделия, Размер, Диаметр, Стандарт, Прочность, Покрытие,
//   Статус, НеЗаполнено, НашаНоменклатура, УИД_1С, РежимПодбора, Совпадение
//
// Группы формы:
//   СтраницаВыборИсточника  (этап 1)
//   СтраницаРезультат       (этап 2)
//   ГруппаТекстМП           (видима при ИсточникДанных = 0)
//   ГруппаФайл              (видима при ИсточникДанных = 1)
//   ГруппаКнопкиЭтап1       (Далее)
//   ГруппаКнопкиЭтап2       (Назад)
//
// Команды формы:
//   Далее, Назад, ВыбратьФайл, ПроверитьСвязь
// ============================================================================


#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ТекущийЭтап = 0;
	ИсточникДанных = 0;
	ОбновитьВидимость();
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ИсточникДанныхПриИзменении(Элемент)
	ОбновитьВидимость();
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы

// ── Этап 1 → Этап 2: Распознать ─────────────────────────────────────────────

&НаКлиенте
Процедура Далее(Команда)

	// Проверка ввода
	Если ИсточникДанных = 0 И ПустаяСтрока(ТекстОтМП) Тогда
		ПоказатьПредупреждение(, "Вставьте текст сообщения от менеджера по продажам.");
		Возврат;
	КонецЕсли;

	Если ИсточникДанных = 1 И ПустаяСтрока(ПутьКФайлу) Тогда
		ПоказатьПредупреждение(, "Укажите файл заявки.");
		Возврат;
	КонецЕсли;

	// Очистить предыдущий результат
	Позиции.Очистить();
	ТекстСтатистики = "";
	ТекстПредупреждений = "";

	// Вызов API через общий модуль
	Если ИсточникДанных = 0 Тогда
		Результат = РазборЗаявокAPI.РазобратьТекст(ТекстОтМП);
	Иначе
		Результат = РазборЗаявокAPI.РазобратьФайл(ПутьКФайлу);
	КонецЕсли;

	Если НЕ Результат.Успех Тогда
		ПоказатьПредупреждение(, Результат.Ошибка);
		Возврат;
	КонецЕсли;

	Если Результат.ВсегоСтрок = 0 Тогда
		ПоказатьПредупреждение(, "Позиции не найдены. Проверьте введённые данные.");
		Возврат;
	КонецЕсли;

	// Заполняем таблицу
	КоличествоАвто = 0;
	КоличествоПредложено = 0;
	КоличествоНеНайдено = 0;
	ПозицииБезПолей = Новый Массив;

	Для Каждого Поз Из Результат.Позиции Цикл
		НоваяСтрока = Позиции.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Поз);

		// Счётчики подбора
		Если Поз.РежимПодбора = "авто" Тогда
			КоличествоАвто = КоличествоАвто + 1;
		ИначеЕсли Поз.РежимПодбора = "предложено" Тогда
			КоличествоПредложено = КоличествоПредложено + 1;
		Иначе
			КоличествоНеНайдено = КоличествоНеНайдено + 1;
		КонецЕсли;

		// Собираем позиции с пропущенными полями
		Если НЕ ПустаяСтрока(Поз.НеЗаполнено) Тогда
			ПозицииБезПолей.Добавить(
				"Стр. " + Поз.НомерСтроки + ": " + Поз.НеЗаполнено);
		КонецЕсли;
	КонецЦикла;

	// Статистика
	Стат = Результат.СтатистикаСтатусов;
	ТекстСтатистики = "Позиций: " + Результат.ВсегоСтрок
		+ "   |   Подбор:  авто " + КоличествоАвто
		+ ",  предложено " + КоличествоПредложено
		+ ",  не найдено " + КоличествоНеНайдено
		+ "   |   Статус:  OK " + Стат.ОК
		+ ",  проверить " + Стат.НаПроверку
		+ ",  вручную " + Стат.Вручную;

	// Предупреждения о пропущенных полях
	Если ПозицииБезПолей.Количество() > 0 Тогда
		ТекстПредупреждений = СтрСоединить(ПозицииБезПолей, Символы.ПС);
	КонецЕсли;

	// Переключаем на этап 2
	ТекущийЭтап = 1;
	ОбновитьВидимость();

	ПоказатьОповещениеПользователя("Разбор завершён", , ТекстСтатистики);

КонецПроцедуры


// ── Этап 2 → Этап 1: Назад ──────────────────────────────────────────────────

&НаКлиенте
Процедура Назад(Команда)
	ТекущийЭтап = 0;
	ОбновитьВидимость();
КонецПроцедуры


// ── Выбор файла ─────────────────────────────────────────────────────────────

&НаКлиенте
Процедура ВыбратьФайл(Команда)

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр = "Excel (*.xlsx)|*.xlsx|CSV (*.csv)|*.csv|Все файлы (*.*)|*.*";
	Диалог.Заголовок = "Выберите файл заявки клиента";

	Если Диалог.Выбрать() Тогда
		ПутьКФайлу = Диалог.ПолноеИмяФайла;
	КонецЕсли;

КонецПроцедуры


// ── Проверка связи ──────────────────────────────────────────────────────────

&НаКлиенте
Процедура ПроверитьСвязь(Команда)
	Результат = РазборЗаявокAPI.ПроверитьСоединение();
	ПоказатьПредупреждение(, Результат.Текст);
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедуры

&НаКлиенте
Процедура ОбновитьВидимость()

	ЭтоЭтап1 = (ТекущийЭтап = 0);
	ЭтоЭтап2 = (ТекущийЭтап = 1);

	// Страницы
	Элементы.СтраницаВыборИсточника.Видимость = ЭтоЭтап1;
	Элементы.СтраницаРезультат.Видимость       = ЭтоЭтап2;

	// Внутри этапа 1: текст / файл
	Элементы.ГруппаТекстМП.Видимость = ЭтоЭтап1 И (ИсточникДанных = 0);
	Элементы.ГруппаФайл.Видимость    = ЭтоЭтап1 И (ИсточникДанных = 1);

	// Кнопки
	Элементы.ГруппаКнопкиЭтап1.Видимость = ЭтоЭтап1;
	Элементы.ГруппаКнопкиЭтап2.Видимость = ЭтоЭтап2;

КонецПроцедуры

#КонецОбласти
