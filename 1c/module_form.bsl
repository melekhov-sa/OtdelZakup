// ============================================================================
// Модуль формы обработки «Разбор заявки клиента»
// Вся логика — в общем модуле РазборЗаявокAPI (Клиент)
// ============================================================================

#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ТипВвода = 0;
	УстановитьВидимостьПоТипу();
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ТипВводаПриИзменении(Элемент)
	УстановитьВидимостьПоТипу();
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура РазобратьЗаявку(Команда)

	Если ТипВвода = 0 И ПустаяСтрока(ТекстЗаявки) Тогда
		ПоказатьПредупреждение(, "Введите текст заявки.");
		Возврат;
	КонецЕсли;

	Если ТипВвода = 1 И ПустаяСтрока(ПутьКФайлу) Тогда
		ПоказатьПредупреждение(, "Укажите путь к файлу.");
		Возврат;
	КонецЕсли;

	Позиции.Очистить();
	ТекстСтатистики = "";

	Если ТипВвода = 0 Тогда
		Результат = РазборЗаявокAPI.РазобратьТекст(ТекстЗаявки);
	Иначе
		Результат = РазборЗаявокAPI.РазобратьФайл(ПутьКФайлу);
	КонецЕсли;

	Если НЕ Результат.Успех Тогда
		ПоказатьПредупреждение(, Результат.Ошибка);
		Возврат;
	КонецЕсли;

	Для Каждого Поз Из Результат.Позиции Цикл
		НоваяСтрока = Позиции.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Поз);
	КонецЦикла;

	Стат = Результат.СтатистикаСтатусов;
	ТекстСтатистики = "Всего: " + Результат.ВсегоСтрок
		+ "  |  OK: " + Стат.ОК
		+ "  |  На проверку: " + Стат.НаПроверку
		+ "  |  Вручную: " + Стат.Вручную;

	ПоказатьОповещениеПользователя("Разбор заявки", , ТекстСтатистики);

КонецПроцедуры


&НаКлиенте
Процедура ПроверитьСвязь(Команда)

	Результат = РазборЗаявокAPI.ПроверитьСоединение();
	ПоказатьПредупреждение(, Результат.Текст);

КонецПроцедуры


&НаКлиенте
Процедура ВыбратьФайл(Команда)

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр = "Excel (*.xlsx)|*.xlsx|CSV (*.csv)|*.csv|Все файлы (*.*)|*.*";
	Диалог.Заголовок = "Выберите файл заявки";

	Если Диалог.Выбрать() Тогда
		ПутьКФайлу = Диалог.ПолноеИмяФайла;
	КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура Очистить(Команда)
	Позиции.Очистить();
	ТекстСтатистики = "";
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьПоТипу()
	Элементы.ГруппаТекст.Видимость = (ТипВвода = 0);
	Элементы.ГруппаФайл.Видимость  = (ТипВвода = 1);
КонецПроцедуры

#КонецОбласти
