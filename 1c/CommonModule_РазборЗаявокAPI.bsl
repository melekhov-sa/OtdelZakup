// ============================================================================
// Общий модуль: РазборЗаявокAPI
// Клиент (управляемое приложение)
//
// Назначение: взаимодействие с сервисом разбора заявок (FastAPI).
// Вызывается из клиентских процедур формы:
//   РазборЗаявокAPI.РазобратьТекст("Болт М12х80 100 шт")
//   РазборЗаявокAPI.РазобратьФайл("C:\file.xlsx")
//   РазборЗаявокAPI.ПроверитьСоединение()
// ============================================================================


#Область ПрограммныйИнтерфейс

// Проверяет доступность сервиса.
//
// Возвращаемое значение:
//   Структура:
//     Успех   - Булево
//     Текст   - Строка
//
Функция ПроверитьСоединение() Экспорт

	Настройки = ПолучитьНастройкиПодключения();

	Попытка
		Соединение = СоздатьСоединение(Настройки);
		Запрос = Новый HTTPЗапрос("/docs");
		Ответ = Соединение.Получить(Запрос);

		Если Ответ.КодСостояния = 200 Тогда
			Возврат Новый Структура("Успех, Текст", Истина,
				"Сервис доступен: " + Настройки.Адрес + ":" + Формат(Настройки.Порт, "ЧГ="));
		Иначе
			Возврат Новый Структура("Успех, Текст", Ложь,
				"Сервис вернул код " + Ответ.КодСостояния);
		КонецЕсли;

	Исключение
		Возврат Новый Структура("Успех, Текст", Ложь,
			"Нет соединения: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции


// Разбирает текст заявки клиента.
//
// Параметры:
//   ТекстЗаявки - Строка - свободный текст, каждая строка = позиция
//
// Возвращаемое значение:
//   Структура:
//     Успех              - Булево
//     Ошибка             - Строка
//     Позиции            - Массив из Структура
//     ВсегоСтрок         - Число
//     СтатистикаСтатусов - Структура (ОК, НаПроверку, Вручную)
//
Функция РазобратьТекст(ТекстЗаявки) Экспорт

	Если ПустаяСтрока(ТекстЗаявки) Тогда
		Возврат РезультатОшибка("Текст заявки пуст.");
	КонецЕсли;

	Настройки = ПолучитьНастройкиПодключения();

	Граница = СоздатьГраницу();
	ТелоСтрока = "--" + Граница + Символы.ВК + Символы.ПС
		+ "Content-Disposition: form-data; name=""text""" + Символы.ВК + Символы.ПС
		+ Символы.ВК + Символы.ПС
		+ ТекстЗаявки + Символы.ВК + Символы.ПС
		+ "--" + Граница + "--" + Символы.ВК + Символы.ПС;

	Запрос = Новый HTTPЗапрос("/api/v1/parse-request");
	Запрос.Заголовки.Вставить("Content-Type", "multipart/form-data; boundary=" + Граница);
	Запрос.УстановитьТелоИзСтроки(ТелоСтрока, КодировкаТекста.UTF8);

	Возврат ВыполнитьЗапросРазбора(Настройки, Запрос);

КонецФункции


// Разбирает файл заявки клиента (Excel, CSV, PDF или изображение).
// Файл отправляется через JSON + Base64 — надёжнее multipart из 1С.
// PDF и изображения обрабатываются через Google Document AI на сервере.
//
// Параметры:
//   ПутьКФайлу    - Строка - полный путь к файлу на диске
//   РежимРазбора  - Строка - подсказка для PDF/изображений:
//                    "table"           — предпочесть таблицу (по умолчанию)
//                    "structured_text" — структурированный список (нумерованный и т.п.)
//                    "free_text"       — свободный текст, все абзацы без фильтрации
//
// Возвращаемое значение:
//   Структура — аналогично РазобратьТекст()
//
Функция РазобратьФайл(ПутьКФайлу, РежимРазбора = "table") Экспорт

	ФайлНаДиске = Новый Файл(ПутьКФайлу);
	Если НЕ ФайлНаДиске.Существует() Тогда
		Возврат РезультатОшибка("Файл не найден: " + ПутьКФайлу);
	КонецЕсли;

	Настройки = ПолучитьНастройкиПодключения();

	// Читаем файл и кодируем в Base64
	ДвоичныеДанные = Новый ДвоичныеДанные(ПутьКФайлу);
	СтрокаBase64 = Base64Строка(ДвоичныеДанные);
	// Base64Строка добавляет переносы строк каждые 76 символов — убираем их
	СтрокаBase64 = СтрЗаменить(СтрокаBase64, Символы.ПС, "");
	СтрокаBase64 = СтрЗаменить(СтрокаBase64, Символы.ВК, "");

	// Отправляем JSON
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	ЗаписьJSON.ЗаписатьИмяСвойства("file_base64");
	ЗаписьJSON.ЗаписатьЗначение(СтрокаBase64);
	ЗаписьJSON.ЗаписатьИмяСвойства("filename");
	ЗаписьJSON.ЗаписатьЗначение(ФайлНаДиске.Имя);
	ЗаписьJSON.ЗаписатьИмяСвойства("hint");
	ЗаписьJSON.ЗаписатьЗначение(РежимРазбора);
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	ТелоJSON = ЗаписьJSON.Закрыть();

	Запрос = Новый HTTPЗапрос("/api/v1/parse-request-base64");
	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	Запрос.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8);

	Возврат ВыполнитьЗапросРазбора(Настройки, Запрос);

КонецФункции


// Возвращает пустую структуру позиции.
//
Функция СтруктураПозиции() Экспорт

	Возврат Новый Структура(
		"НомерСтроки, Наименование, Количество, ЕдИзмерения,
		|ТипИзделия, Размер, Диаметр, Стандарт, Прочность, Покрытие,
		|Статус, НеЗаполнено, НашаНоменклатура, УИД_1С, РежимПодбора, Совпадение,
		|Кандидаты",
		0, "", 0, "",
		"", "", "", "", "", "",
		"", "", "", "", "", 0,
		Новый Массив);

КонецФункции

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Функция ПолучитьНастройкиПодключения()

	// Значения по умолчанию — меняй здесь если нужен другой адрес/порт
	Адрес   = "127.0.0.1";
	Порт    = 8000;
	Таймаут = 60;

	Возврат Новый Структура("Адрес, Порт, Таймаут", Адрес, Порт, Таймаут);

КонецФункции


Функция СоздатьСоединение(Настройки)

	Возврат Новый HTTPСоединение(
		Настройки.Адрес,
		Настройки.Порт,
		, , ,
		Настройки.Таймаут);

КонецФункции


Функция ВыполнитьЗапросРазбора(Настройки, Запрос)

	Попытка
		Соединение = СоздатьСоединение(Настройки);
		Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	Исключение
		Возврат РезультатОшибка("Нет соединения с сервисом ("
			+ Настройки.Адрес + ":" + Формат(Настройки.Порт, "ЧГ=")
			+ "): " + ОписаниеОшибки());
	КонецПопытки;

	Если Ответ.КодСостояния <> 200 Тогда
		ТекстТела = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
		Возврат РезультатОшибка("Сервис вернул ошибку (код " + Ответ.КодСостояния + "): " + ТекстТела);
	КонецЕсли;

	ТелоСтрока = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);

	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТелоСтрока);
		Данные = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		Возврат РезультатОшибка("Ошибка разбора JSON: " + ОписаниеОшибки());
	КонецПопытки;

	Возврат РазобратьОтветJSON(Данные);

КонецФункции


Функция РазобратьОтветJSON(Данные)

	// ПрочитатьJSON может вернуть Соответствие или Структура в зависимости от версии платформы
	Если ТипЗнч(Данные) <> Тип("Соответствие") И ТипЗнч(Данные) <> Тип("Структура") Тогда
		Возврат РезультатОшибка("Неожиданный формат ответа: " + ТипЗнч(Данные));
	КонецЕсли;

	ТекстОшибки = ПолучитьЗначение(Данные, "error", "");
	Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
		Возврат РезультатОшибка(ТекстОшибки);
	КонецЕсли;

	МассивСтрок = ПолучитьЗначение(Данные, "rows", Неопределено);
	Если МассивСтрок = Неопределено Тогда
		Возврат РезультатОшибка("Позиции не найдены в ответе.");
	КонецЕсли;

	Позиции = Новый Массив;
	СчётчикОК = 0;
	СчётчикReview = 0;
	СчётчикManual = 0;

	Для Каждого СтрокаJSON Из МассивСтрок Цикл

		Поз = СтруктураПозиции();

		Поз.НомерСтроки  = ПолучитьЗначение(СтрокаJSON, "row_no", 0);
		Поз.Наименование = ПолучитьЗначение(СтрокаJSON, "name", "");
		Поз.Количество   = ПолучитьЗначение(СтрокаJSON, "qty", 0);
		Поз.ЕдИзмерения  = ПолучитьЗначение(СтрокаJSON, "unit", "");
		Поз.ТипИзделия   = ПолучитьЗначение(СтрокаJSON, "item_type", "");
		Поз.Размер       = ПолучитьЗначение(СтрокаJSON, "size", "");
		Поз.Диаметр      = ПолучитьЗначение(СтрокаJSON, "diameter", "");
		Поз.Прочность    = ПолучитьЗначение(СтрокаJSON, "strength", "");
		Поз.Покрытие     = ПолучитьЗначение(СтрокаJSON, "coating", "");
		Поз.Статус       = ПолучитьЗначение(СтрокаJSON, "row_status", "");

		Стандарт = ПолучитьЗначение(СтрокаJSON, "gost", "");
		Если ПустаяСтрока(Стандарт) Тогда
			Стандарт = ПолучитьЗначение(СтрокаJSON, "din", "");
		КонецЕсли;
		Если ПустаяСтрока(Стандарт) Тогда
			Стандарт = ПолучитьЗначение(СтрокаJSON, "iso", "");
		КонецЕсли;
		Поз.Стандарт = Стандарт;

		МассивНеЗаполнено = ПолучитьЗначение(СтрокаJSON, "missing_fields", Неопределено);
		Если МассивНеЗаполнено <> Неопределено И ТипЗнч(МассивНеЗаполнено) = Тип("Массив") Тогда
			Если МассивНеЗаполнено.Количество() > 0 Тогда
				Поз.НеЗаполнено = "Не заполнено: " + СтрСоединить(МассивНеЗаполнено, ", ");
			КонецЕсли;
		КонецЕсли;

		Подбор = ПолучитьЗначение(СтрокаJSON, "match", Неопределено);
		Если Подбор <> Неопределено
			И (ТипЗнч(Подбор) = Тип("Соответствие") ИЛИ ТипЗнч(Подбор) = Тип("Структура")) Тогда
			Поз.НашаНоменклатура = ПолучитьЗначение(Подбор, "name", "");
			Поз.УИД_1С           = ПолучитьЗначение(Подбор, "uid_1c", "");
			Поз.РежимПодбора     = ПолучитьЗначение(Подбор, "match_mode", "");
			Поз.Совпадение       = ПолучитьЗначение(Подбор, "score", 0);
		КонецЕсли;

		Если Поз.Статус = "ok" Тогда
			СчётчикОК = СчётчикОК + 1;
		ИначеЕсли Поз.Статус = "review" Тогда
			СчётчикReview = СчётчикReview + 1;
		Иначе
			СчётчикManual = СчётчикManual + 1;
		КонецЕсли;

		Позиции.Добавить(Поз);

	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("Успех", Истина);
	Результат.Вставить("Ошибка", "");
	Результат.Вставить("Позиции", Позиции);
	Результат.Вставить("ВсегоСтрок", Позиции.Количество());
	Результат.Вставить("СтатистикаСтатусов", Новый Структура(
		"ОК, НаПроверку, Вручную", СчётчикОК, СчётчикReview, СчётчикManual));

	Возврат Результат;

КонецФункции


Функция РезультатОшибка(Текст)

	Возврат Новый Структура(
		"Успех, Ошибка, Позиции, ВсегоСтрок, СтатистикаСтатусов",
		Ложь, Текст, Новый Массив, 0,
		Новый Структура("ОК, НаПроверку, Вручную", 0, 0, 0));

КонецФункции


// Универсальное чтение из Соответствие или Структура
Функция ПолучитьЗначение(Объект, Ключ, ЗначениеПоУмолчанию)

	Значение = Неопределено;

	Если ТипЗнч(Объект) = Тип("Соответствие") Тогда
		Значение = Объект.Получить(Ключ);
	ИначеЕсли ТипЗнч(Объект) = Тип("Структура") Тогда
		Если НЕ Объект.Свойство(Ключ, Значение) Тогда
			Значение = Неопределено;
		КонецЕсли;
	КонецЕсли;

	Если Значение = Неопределено ИЛИ Значение = NULL Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Возврат Значение;

КонецФункции


Функция СоздатьГраницу()

	Возврат "----Boundary" + Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss")
		+ Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=");

КонецФункции


Функция ОпределитьContentType(Расширение)

	Расш = НРег(Расширение);
	Если Расш = ".xlsx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
	ИначеЕсли Расш = ".xls" Тогда
		Возврат "application/vnd.ms-excel";
	ИначеЕсли Расш = ".csv" Тогда
		Возврат "text/csv";
	Иначе
		Возврат "application/octet-stream";
	КонецЕсли;

КонецФункции

#КонецОбласти
