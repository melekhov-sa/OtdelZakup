# ── Google Document AI ────────────────────────────────────────────────────────
# Required for the "Google OCR" import tab.
# All keys are read from environment variables at runtime — never hard-coded.

# GCP project ID (e.g. "my-project-123")
GOOGLE_PROJECT_ID=

# Document AI processor region (e.g. "eu" or "us")
GOOGLE_LOCATION=eu

# Document AI processor ID (found in the GCP Console under Document AI)
GOOGLE_PROCESSOR_ID=

# --- Authentication: choose ONE of the two options below ---

# Option A: service account JSON as a single-line string
#   export GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":...}'
GOOGLE_CREDENTIALS_JSON=

# Option B: path to a service account JSON file (Application Default Credentials)
#   export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# ── Optional features ─────────────────────────────────────────────────────────

# Set to "true" in the DB SystemSetting table (key=google_ocr_save_raw) to
# persist the raw Document AI JSON response alongside the cache files.
# Default: OFF (not saved).
# GOOGLE_OCR_SAVE_RAW=false

# ── Application directories ───────────────────────────────────────────────────
# OTDELZAKUP_UPLOAD_DIR=./data/uploads
# OTDELZAKUP_CACHE_DIR=./data/cache
